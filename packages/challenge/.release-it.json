{
    "git": {
        "requireCleanWorkingDir": false,
        "requireCommits": true,
        "commit": false,
        "tagAnnotation": "challenge-v${version}",
        "tagName": "challenge-v${version}",
        "tagArgs": ["--force"]
    },
    "npm": { "publish": true },
    "github": {
        "release": true,
        "releaseName": "challenge-v${version}"
    },
    "plugins": {
        "@release-it/conventional-changelog": {
            "preset": {
                "name": "conventionalcommits",
                "preMajor": true,
                "types": [
                    { "type": "feat", "section": "Features" },
                    { "type": "fix", "section": "Bug Fixes" },
                    { "type": "perf", "section": "Performance Improvements" },
                    { "type": "revert", "section": "Reverts" },
                    { "type": "build", "section": "Build System" }
                ]
            },
            "infile": "CHANGELOG.md",
            "path": "."
        }
    },
    "hooks": {
        "before:git:release": "cd ../.. && npm install --package-lock-only --ignore-scripts && cd packages/challenge && git add CHANGELOG.md package.json ../../package-lock.json && git commit -m 'chore(release): challenge v${version} [skip ci]'"
    }
}
