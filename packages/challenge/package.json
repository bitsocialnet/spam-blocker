{
    "name": "@bitsocial/spam-blocker-challenge",
    "version": "0.0.0",
    "description": "Bitsocial Spam Blocker challenge implementation for PKC",
    "license": "GPL-3.0-or-later",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "package.json"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "yarn workspace @bitsocial/spam-blocker-shared build && node esbuild.config.js && tsc -p tsconfig.json --emitDeclarationOnly",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "type-check": "yarn workspace @bitsocial/spam-blocker-shared build && tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@noble/ed25519": "1.7.5",
        "@pkc/pkc-logger": "https://github.com/pkcprotocol/pkc-logger.git",
        "@pkcprotocol/pkc-js": "https://github.com/pkcprotocol/pkc-js.git#e63026e6cd33df5af3a3b5e6473b1e364d89fbdb",
        "cborg": "4.3.2",
        "i18n-iso-countries": "7.14.0",
        "multiformats": "9.9.0",
        "uint8arrays": "5.1.0",
        "zod": "4.3.5"
    },
    "devDependencies": {
        "esbuild": "0.27.2",
        "typescript": "6.0.2",
        "vitest": "4.0.16"
    }
}
