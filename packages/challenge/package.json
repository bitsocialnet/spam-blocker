{
    "name": "@bitsocial/spam-blocker-challenge",
    "version": "0.1.1",
    "description": "Bitsocial Spam Blocker challenge implementation for PKC",
    "keywords": [
        "bitsocial",
        "pkc",
        "challenge",
        "spam",
        "moderation"
    ],
    "author": "Bitsocial Labs",
    "license": "GPL-3.0-or-later",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "package.json"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bitsocialnet/spam-blocker.git",
        "directory": "packages/challenge"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "yarn workspace @bitsocial/spam-blocker-shared build && node esbuild.config.js && tsc -p tsconfig.json --emitDeclarationOnly",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "type-check": "yarn workspace @bitsocial/spam-blocker-shared build && tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@noble/ed25519": "1.7.5",
        "@pkcprotocol/pkc-js": "0.0.18",
        "@pkcprotocol/pkc-logger": "0.1.0",
        "cborg": "4.3.2",
        "i18n-iso-countries": "7.14.0",
        "multiformats": "9.9.0",
        "uint8arrays": "5.1.0",
        "zod": "4.3.5"
    },
    "devDependencies": {
        "esbuild": "0.27.2",
        "typescript": "6.0.2",
        "vitest": "4.0.16"
    },
    "packageManager": "yarn@4.13.0"
}
