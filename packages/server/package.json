{
    "name": "@bitsocial/spam-blocker-server",
    "version": "0.0.0",
    "description": "HTTP server for BitsocialSpamBlocker",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "package.json"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "start": "node --env-file=.env --import tsx dist/index.js",
        "dev": "node --env-file=.env --import tsx src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "generate-scenarios": "node --import tsx scripts/generate-risk-score-scenarios.ts"
    },
    "dependencies": {
        "@bitsocial/spam-blocker-shared": "0.0.0",
        "@noble/ed25519": "1.7.5",
        "@plebbit/plebbit-js": "https://github.com/plebbit/plebbit-js#179ff836fa4d22365406092315a7a1ab014ee0b4",
        "arctic": "3.7.0",
        "better-sqlite3": "12.4.1",
        "cborg": "4.3.2",
        "fastify": "5.6.2",
        "jose": "6.0.11",
        "tsx": "4.19.4",
        "uint8arrays": "5.1.0",
        "zod": "4.3.5"
    },
    "devDependencies": {
        "@types/better-sqlite3": "7.6.13",
        "@types/node": "22.15.21",
        "pino-pretty": "13.1.3",
        "typescript": "5.9.3",
        "vitest": "4.0.16"
    }
}
