{
    "name": "@bitsocial/spam-blocker-shared",
    "version": "0.1.0",
    "description": "Shared types and schemas for bitsocial/spam-blocker",
    "author": "Bitsocial Forge",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "main": "dist/types.js",
    "types": "dist/types.d.ts",
    "files": [
        "dist",
        "package.json"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.js",
            "require": "./dist/types.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist",
        "type-check": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "i18n-iso-countries": "7.14.0",
        "zod": "4.3.5"
    },
    "devDependencies": {
        "typescript": "6.0.2"
    }
}
