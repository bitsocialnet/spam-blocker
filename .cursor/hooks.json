{
    "version": 1,
    "hooks": {
        "afterFileEdit": [
            {
                "command": ".cursor/hooks/format.sh",
                "timeout": 10
            },
            {
                "command": ".cursor/hooks/yarn-install.sh",
                "timeout": 120
            }
        ],
        "stop": [
            {
                "command": ".cursor/hooks/sync-git-branches.sh",
                "timeout": 60
            },
            {
                "command": ".cursor/hooks/verify.sh",
                "timeout": 60
            }
        ]
    }
}
